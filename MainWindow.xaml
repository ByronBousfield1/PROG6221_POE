<Window x:Class="CyberAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="780" Width="1020"
        MinHeight="600" MinWidth="800"
        Background="{StaticResource BackgroundDark}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BackgroundMid}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="14,18,14,10">
                    <StackPanel>
                        <TextBlock Text="CYBER AWARENESS"
                                   FontFamily="Consolas" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource AccentGreen}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AsciiArtBlock"
                                   FontFamily="Consolas" FontSize="9"
                                   Foreground="{StaticResource AccentGreen}"
                                   TextWrapping="NoWrap"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="v2.0 GUI Edition"
                                   FontFamily="Consolas" FontSize="10"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource BackgroundCard}"
                        CornerRadius="6" Margin="14,8,14,8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="USER PROFILE"
                                   Foreground="{StaticResource AccentCyan}"
                                   FontSize="11" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">Name</TextBlock>
                        <TextBlock x:Name="ProfileNameText"
                                   Text="(not set)"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontWeight="SemiBold" FontSize="13"
                                   Margin="0,2,0,8"/>

                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">Favourite Topic</TextBlock>
                        <TextBlock x:Name="ProfileTopicText"
                                   Text="-"
                                   Foreground="{StaticResource AccentGreen}"
                                   FontWeight="SemiBold" FontSize="13"
                                   Margin="0,2,0,8"/>

                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">Last Sentiment</TextBlock>
                        <TextBlock x:Name="ProfileSentimentText"
                                   Text="neutral"
                                   Foreground="{StaticResource AccentYellow}"
                                   FontWeight="SemiBold" FontSize="13"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="14,4,14,4">
                    <StackPanel>
                        <TextBlock Text="QUICK TOPICS"
                                   Foreground="{StaticResource AccentCyan}"
                                   FontSize="11" FontWeight="Bold"
                                   Margin="0,4,0,8"/>
                        <ItemsControl x:Name="TopicChipsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Style="{StaticResource CyberButton}"
                                            Background="{StaticResource BackgroundCard}"
                                            Foreground="{StaticResource AccentGreen}"
                                            FontWeight="Normal"
                                            FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,0,0,6"
                                            Padding="10,6"
                                            Click="TopicChip_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="14,10">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText"
                                   Text="Online - ready"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BackgroundMid}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                    Padding="20,14">
                <StackPanel>
                    <TextBlock Text="Cybersecurity Awareness Bot"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Helping South African citizens stay safe online"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource BackgroundDark}"
                          Padding="20">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{StaticResource BackgroundMid}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="InputBox"
                             Grid.Column="0"
                             Style="{StaticResource CyberTextBox}"
                             KeyDown="InputBox_KeyDown"/>

                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Content="SEND"
                            Style="{StaticResource CyberButton}"
                            Margin="10,0,0,0"
                            Click="SendButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
