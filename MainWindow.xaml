<Window x:Class="CyberAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="820" Width="1080"
        MinHeight="640" MinWidth="900"
        Background="{StaticResource BackgroundDark}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundMid}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CYBER" FontFamily="Consolas" FontWeight="Bold"
                           FontSize="22" Foreground="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Cybersecurity Awareness Bot"
                               FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Helping South African citizens stay safe online"
                               FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" x:Name="MainTabs" Background="Transparent" BorderThickness="0" Padding="0">

            <!-- ===== CHAT TAB ===== -->
            <TabItem Header="Chat">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Mini sidebar: profile + quick topics -->
                    <Border Grid.Column="0" Background="{StaticResource BackgroundMid}"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource BackgroundCard}"
                                    CornerRadius="6" Margin="12,12,12,8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="USER PROFILE" Foreground="{StaticResource AccentCyan}"
                                               FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">Name</TextBlock>
                                    <TextBlock x:Name="ProfileNameText" Text="(not set)" Foreground="{StaticResource TextPrimary}"
                                               FontWeight="SemiBold" FontSize="13" Margin="0,2,0,8"/>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">Favourite Topic</TextBlock>
                                    <TextBlock x:Name="ProfileTopicText" Text="-" Foreground="{StaticResource AccentGreen}"
                                               FontWeight="SemiBold" FontSize="13" Margin="0,2,0,8"/>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">Last Sentiment</TextBlock>
                                    <TextBlock x:Name="ProfileSentimentText" Text="neutral" Foreground="{StaticResource AccentYellow}"
                                               FontWeight="SemiBold" FontSize="13" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="12,4,12,12">
                                <StackPanel>
                                    <TextBlock Text="QUICK TOPICS" Foreground="{StaticResource AccentCyan}"
                                               FontSize="11" FontWeight="Bold" Margin="0,4,0,8"/>
                                    <ItemsControl x:Name="TopicChipsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding}" Style="{StaticResource CyberButtonAlt}"
                                                        Foreground="{StaticResource AccentGreen}" FontSize="12"
                                                        HorizontalAlignment="Stretch" Margin="0,0,0,6" Padding="10,6"
                                                        Click="TopicChip_Click"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Chat area -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource BackgroundDark}" Padding="20">
                            <StackPanel x:Name="ChatPanel"/>
                        </ScrollViewer>

                        <Border Grid.Row="1" Background="{StaticResource BackgroundMid}"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="20,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InputBox" Grid.Column="0" Style="{StaticResource CyberTextBox}"
                                         KeyDown="InputBox_KeyDown"/>
                                <Button x:Name="SendButton" Grid.Column="1" Content="SEND"
                                        Style="{StaticResource CyberButton}" Margin="10,0,0,0" Click="SendButton_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ===== TASKS TAB ===== -->
            <TabItem Header="Tasks">
                <Grid Margin="20,16,20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Add task form -->
                    <Border Grid.Column="0" Background="{StaticResource BackgroundCard}" CornerRadius="8"
                            Padding="16" Margin="0,0,16,0" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Add a Task" Foreground="{StaticResource AccentGreen}"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                            <TextBlock Text="Title" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TaskTitleBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,10"/>

                            <TextBlock Text="Description" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TaskDescBox" Style="{StaticResource CyberTextBox}"
                                     TextWrapping="Wrap" AcceptsReturn="True" Height="70" Margin="0,0,0,10"
                                     VerticalContentAlignment="Top"/>

                            <TextBlock Text="Reminder date (optional)" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <DatePicker x:Name="TaskReminderPicker" Margin="0,0,0,6"/>
                            <TextBlock Text="Or type a timeframe, e.g. 'in 7 days'" Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TaskReminderTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,14"/>

                            <Button Content="ADD TASK" Style="{StaticResource CyberButton}"
                                    HorizontalAlignment="Stretch" Click="AddTaskButton_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Task list -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Your Tasks" Foreground="{StaticResource TextPrimary}"
                                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="Refresh" Style="{StaticResource CyberButtonAlt}"
                                    HorizontalAlignment="Right" Padding="12,6" Click="RefreshTasksButton_Click"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TaskListPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ===== QUIZ TAB ===== -->
            <TabItem Header="Quiz">
                <Grid Margin="20,16,20,16">
                    <Border Background="{StaticResource BackgroundCard}" CornerRadius="8" Padding="24"
                            MaxWidth="720" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <StackPanel>
                            <!-- Start / intro -->
                            <StackPanel x:Name="QuizStartPanel">
                                <TextBlock Text="Cybersecurity Quiz" Foreground="{StaticResource AccentGreen}"
                                           FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Test your knowledge with 14 questions covering phishing, passwords, scams, and more."
                                           Foreground="{StaticResource TextSecondary}" FontSize="13"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,20"/>
                                <Button Content="START QUIZ" Style="{StaticResource CyberButton}"
                                        Width="180" HorizontalAlignment="Center" Click="StartQuizButton_Click"/>
                            </StackPanel>

                            <!-- Active question -->
                            <StackPanel x:Name="QuizQuestionPanel" Visibility="Collapsed">
                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="QuizProgressText" Foreground="{StaticResource AccentCyan}"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="QuizScoreText" Foreground="{StaticResource AccentYellow}"
                                               FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                </Grid>

                                <TextBlock x:Name="QuizQuestionText" Foreground="{StaticResource TextPrimary}"
                                           FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,18"/>

                                <StackPanel x:Name="QuizOptionsPanel"/>

                                <Border x:Name="QuizFeedbackBorder" CornerRadius="6" Padding="14" Margin="0,8,0,0"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="QuizFeedbackTitle" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock x:Name="QuizFeedbackText" Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="QuizNextButton" Content="NEXT" Style="{StaticResource CyberButton}"
                                        Width="140" HorizontalAlignment="Right" Margin="0,16,0,0"
                                        Visibility="Collapsed" Click="QuizNextButton_Click"/>
                            </StackPanel>

                            <!-- Results -->
                            <StackPanel x:Name="QuizResultPanel" Visibility="Collapsed">
                                <TextBlock Text="Quiz Complete" Foreground="{StaticResource AccentGreen}"
                                           FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="QuizResultText" Foreground="{StaticResource TextPrimary}"
                                           FontSize="16" TextWrapping="Wrap" TextAlignment="Center" Margin="0,14,0,20"/>
                                <Button Content="PLAY AGAIN" Style="{StaticResource CyberButton}"
                                        Width="180" HorizontalAlignment="Center" Click="StartQuizButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== ACTIVITY LOG TAB ===== -->
            <TabItem Header="Activity Log">
                <Grid Margin="20,16,20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Activity Log" Foreground="{StaticResource TextPrimary}"
                                   FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Refresh" Style="{StaticResource CyberButtonAlt}"
                                HorizontalAlignment="Right" Padding="12,6" Click="RefreshLogButton_Click"/>
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource BackgroundCard}" CornerRadius="8" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="LogListPanel">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,8" Margin="0,0,0,4" Background="{StaticResource BackgroundMid}" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                                                           Foreground="{StaticResource AccentCyan}" FontFamily="Consolas"
                                                           FontSize="12" Margin="0,0,12,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Description}"
                                                           Foreground="{StaticResource TextPrimary}" FontSize="13"
                                                           TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock x:Name="LogCountText" Foreground="{StaticResource TextSecondary}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button x:Name="LogShowMoreButton" Content="Show all" Style="{StaticResource CyberButtonAlt}"
                                Padding="12,6" Click="LogShowMoreButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BackgroundMid}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Online - ready" Foreground="{StaticResource TextSecondary}"
                               FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="DbStatusText" Text="Database: checking..." HorizontalAlignment="Right"
                           Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
